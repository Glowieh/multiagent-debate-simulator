# AWS region for Bedrock (uses default credential chain / AWS profile)
AWS_REGION=eu-west-1

# EU geo inference profile for Amazon Nova Micro (production default)
# https://docs.aws.amazon.com/bedrock/latest/userguide/inference-profiles-support.html
BEDROCK_MODEL_ID=eu.amazon.nova-micro-v1:0

# Skip npm install inside agentcore dev (Python deps managed by uv)
AGENTCORE_SKIP_INSTALL=1

# Use local Ollama instead of Bedrock (requires Ollama running)
USE_LOCAL_LLM=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-langsmith-api-key>
LANGSMITH_PROJECT="pr-worthwhile-rainy-12"

# Frontend deploy (S3 + CloudFront; fill after terraform apply in terraform/frontend/)
FRONTEND_S3_BUCKET=
FRONTEND_CLOUDFRONT_DISTRIBUTION_ID=
# Build-time API URL for production (API Gateway base URL, no trailing slash)
VITE_API_BASE_URL=
# Production only: set to true to skip login gate when testing a production build locally
# VITE_SKIP_AUTH=true

# Wikipedia API (optional overrides; Wikipedia-API library)
# WIKIPEDIA_USER_AGENT=MultiAgentDebateBot/1.0 (https://github.com/Glowieh/multiagent-debate-simulator)
# WIKIPEDIA_MAX_RETRIES=3
# WIKIPEDIA_RETRY_WAIT=1.0
