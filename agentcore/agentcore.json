{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "DebateAgent",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "DebateAgent"
  },
  "runtimes": [
    {
      "name": "DebateAgent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/DebateAgent/",
      "runtimeVersion": "PYTHON_3_12",
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "envVars": [
        { "name": "USE_LOCAL_LLM", "value": "false" },
        { "name": "BEDROCK_MODEL_ID", "value": "eu.amazon.nova-micro-v1:0" },
        { "name": "AWS_REGION", "value": "eu-west-1" },
        { "name": "LANGSMITH_TRACING", "value": "true" },
        { "name": "LANGSMITH_ENDPOINT", "value": "https://api.smith.langchain.com" },
        { "name": "LANGSMITH_PROJECT", "value": "pr-worthwhile-rainy-12" }
      ]
    }
  ],
  "memories": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": [],
  "harnesses": [],
  "datasets": [],
  "payments": []
}